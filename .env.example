# Copy to `.env` and fill in your own values:  cp .env.example .env
# docker compose reads this automatically. `.env` is gitignored.

# Your SoundTouch's IP address or hostname on the LAN (required).
BOSE_HOST=192.168.1.50

# Display name shown in the app (optional; the app also reads the speaker's own name).
BOSE_NAME=SoundTouch

# Host port the app/proxy is published on (optional; defaults to 80).
PROXY_PORT=80
